    - hdf5_{{versions.hdf5}}_{{compiler}}_{{compiler_version}}
  addfile: hdf5r-{{version}}.patch
  build:
     modules:
      - R/{{Rversion}}
      - hdf5/{{versions.hdf5}}/{{compiler}}.{{compiler_version}} 
  install:
     makeinstall: >
       tar xzvf {{src_tarball}};
       cd hdf5r; 
       patch -p1 < ../{{addfile}};
       if [[ "{{compiler_version}}" > "15" ]]; then export export CFLAGS="-Wno-error=implicit-function-declaration"; fi;
       autoreconf;
       mkdir -p $(ROOT)/{{libpath}};
       R CMD INSTALL -l $(ROOT)/{{libpath}} .
  release: 2
